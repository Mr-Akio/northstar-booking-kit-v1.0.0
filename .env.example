# Local defaults
DJANGO_SECRET_KEY=replace-me-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://booking:booking@postgres:5432/booking
DATABASE_SSL_REQUIRED=False
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@northstar.local
FRONTEND_URL=http://localhost:3000
BOOKING_PENDING_LOCKS_SLOT=False
BOOKING_DEFAULT_CURRENCY=USD
REFRESH_COOKIE_NAME=northstar_refresh
REFRESH_COOKIE_SECURE=False
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_PATH=/api/v1/auth/
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_THEME_PRESET=default

# Hosted demo notes
# Neon -> DATABASE_URL=postgresql://...neon.tech/...?...sslmode=require
# Render backend -> DJANGO_DEBUG=False
# Render backend -> DATABASE_SSL_REQUIRED=True
# Render backend -> DJANGO_ALLOWED_HOSTS=<your-render-service>.onrender.com
# Render backend -> CORS_ALLOWED_ORIGINS=https://<your-vercel-project>.vercel.app
# Render backend -> CSRF_TRUSTED_ORIGINS=https://<your-vercel-project>.vercel.app
# Render backend -> FRONTEND_URL=https://<your-vercel-project>.vercel.app
# Render backend -> REFRESH_COOKIE_SECURE=True
# Render backend -> REFRESH_COOKIE_SAMESITE=None
# Render backend -> SESSION_COOKIE_SECURE=True
# Render backend -> CSRF_COOKIE_SECURE=True
# Vercel frontend -> NEXT_PUBLIC_API_URL=https://<your-render-service>.onrender.com
